    "})\n",
    "y_small = np.array([0, 1, 0, 1])\n",
    "\n",
    "m = XGBClassifier(\n",
    "    n_estimators=5,\n",
    "    max_depth=2,\n",
    "    learning_rate=0.1,\n",
    "    objective=\"binary:logistic\",\n",
