    "def choose_dependence_features(shap_table: pd.DataFrame, output_dir: Path) -> tuple[list[str], pd.DataFrame]:\n",
    "    \"\"\"\n",
    "    Locked dependence-plot rule:\n",
    "    - start from mean absolute SHAP ranking\n",
    "    - exclude helper/coverage indicators\n",
