    "    random_state=42,\n",
    "    verbosity=0\n",
    ")\n",
    "m.fit(X_small, y_small)\n",
    "\n",
    "explainer = shap.TreeExplainer(m)\n",
    "sv = explainer.shap_values(X_small)\n",
    "\n",
    "print(\"SHAP + XGBoost test OK\")"
