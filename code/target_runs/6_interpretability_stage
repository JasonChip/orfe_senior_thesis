    "    ]\n",
    "    main_table = table.loc[:, main_cols].head(TOP_K_LINEAR_MAIN).copy()\n",
    "    main_table.to_csv(output_dir / \"l4_main_text_top_features.csv\", index=False)\n",
    "\n",
    "    return table, main_table"
