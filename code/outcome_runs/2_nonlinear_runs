    "            'pr_auc': float(selected_cv_df['pr_auc'].mean()),\n",
    "            'roc_auc': float(selected_cv_df['roc_auc'].mean()),\n",
    "            'brier_score': float(selected_cv_df['brier_score'].mean()),\n",
