    "            'selected_max_depth': selected_max_depth,\n",
    "            'selected_learning_rate': selected_learning_rate,\n",
    "            'selected_min_child_weight': selected_min_child_weight,\n",
    "            'selected_subsample': selected_subsample,\n",
