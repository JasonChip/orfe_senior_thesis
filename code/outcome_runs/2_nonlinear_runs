    "    \"log_tobins_q_rel_peer\",\n",
    "    \"log_ev_to_ebitda_rel_peer\",\n",
    "    \"ebitda_margin_rel_peer\",\n",
    "    \"sales_growth_rel_peer\",\n",
    "    \"roe_rel_peer\",\n",
    "    \"board_size\",\n",
