    "    \"ceo_is_female\",\n",
    "    \"ceo_chair_duality\",\n",
    "    \"ceo_match_found\",\n",
    "    \"ceo_stale_gt_365\",\n",
    "    \"inst_match_found\",\n",
    "    \"demand_group_board_governance\",\n",
    "    \"demand_group_ma_strategic_alternatives\",\n",
